---
/**
 * Real per-project page. This used to be a <meta refresh> stub that bounced to
 * /showcase?project=<slug>; it now renders the project, so the URL is a genuine
 * destination — Plausible records it as an ordinary pageview, and there's no
 * redirect hop between a shared link and the content.
 *
 * StarlightPage wraps it in the site chrome (header, footer, theme) even though
 * it lives in src/pages rather than the docs collection.
 */
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

import { ProjectPage } from '@/components/showcase/ProjectPage';

export async function getStaticPaths() {
  const showcaseEntries = await getCollection('showcase');
  return showcaseEntries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { project: entry.data },
  }));
}

const { project } = Astro.props;
const { slug } = Astro.params;

// First screenshot makes a better card than the generic OG image.
const ogImage =
  project.screenshots && project.screenshots.length > 0
    ? `https://docs.hardcover.app${project.screenshots[0].src}`
    : 'https://docs.hardcover.app/og-image.png';

const pageTitle = `${project.name} - Community Showcase | Hardcover Docs`;
const canonicalUrl = `https://docs.hardcover.app/showcase/${slug}`;
---

<StarlightPage
    frontmatter={{
        title: project.name,
        description: project.summary,
        template: 'splash',
        tableOfContents: false,
        editUrl: false,
        next: false,
        prev: false,
        head: [
            {tag: 'meta', attrs: {property: 'og:title', content: pageTitle}},
            {tag: 'meta', attrs: {property: 'og:description', content: project.summary}},
            {tag: 'meta', attrs: {property: 'og:image', content: ogImage}},
            {tag: 'meta', attrs: {property: 'og:url', content: canonicalUrl}},
            {tag: 'meta', attrs: {property: 'og:type', content: 'article'}},
            {tag: 'meta', attrs: {name: 'twitter:card', content: 'summary_large_image'}},
            {tag: 'meta', attrs: {name: 'twitter:title', content: pageTitle}},
            {tag: 'meta', attrs: {name: 'twitter:description', content: project.summary}},
            {tag: 'meta', attrs: {name: 'twitter:image', content: ogImage}},
        ],
    }}
    hasSidebar={false}
>
    <ProjectPage project={project} client:load/>
</StarlightPage>
