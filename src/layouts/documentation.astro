---
import {Badge} from '@astrojs/starlight/components';

import {uCFirst, useTranslation} from "@/lib/utils";
import type { FrontmatterConfig } from '@/types';
import { Components } from "@/components";

const {category, lastUpdated} = Astro.props.frontmatter as FrontmatterConfig;

const locale = Astro.currentLocale;

// Prefer Starlight's resolved last-updated (git commit date when there's no
// frontmatter override) over the raw frontmatter value.
const resolvedLastUpdated =
    Astro.locals.starlightRoute?.lastUpdated ??
    (lastUpdated ? new Date(lastUpdated) : undefined);
---

<div class="flex flex-auto flex-row justify-between mb-4">
    <p class="text-sm inline-block self-start">
        {resolvedLastUpdated && (
                <>
                    {useTranslation('ui.lastUpdated', locale)} &nbsp; {resolvedLastUpdated.toLocaleDateString(locale, {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                })}
                </>
        )}
    </p>
    {category && (
            <Badge text={uCFirst(category)} variant="note" class="w-fit"/>
    )}
</div>

<Components.banners.api locale={locale} client:only="react"/>

<slot/>