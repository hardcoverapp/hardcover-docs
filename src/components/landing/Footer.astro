---
/**
 * Footer — marketing footer for the landing (and later showcase). Brand + tagline
 * + app links, three link columns, and a bottom bar with copyright + socials.
 * Copy/layout from the design mock; token-styled and reusable.
 */
import { URLS } from '@/Consts';
import SocialIcons from '@/components/SocialIcons.astro';

const columns = [
  {
    title: 'Docs',
    links: [
      { label: 'Getting started', href: '/api/getting-started' },
      { label: 'API guides', href: '/api/guides' },
      { label: 'GraphQL schemas', href: '/api/graphql/schemas' },
      { label: 'Librarian guide', href: '/librarians/getting-started' },
    ],
  },
  {
    title: 'Community',
    links: [
      { label: 'Showcase', href: '/showcase' },
      { label: 'Discord', href: URLS.DISCORD },
      { label: 'GitHub', href: URLS.GITHUB },
      { label: 'Contribute', href: '/contributing' },
    ],
  },
  {
    title: 'Hardcover',
    links: [
      { label: 'Open the app', href: URLS.APP },
      { label: 'Download for iOS', href: URLS.APP_STORE },
      { label: 'Download for Android', href: URLS.PLAY_STORE },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="site-footer not-content">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-mark">
          <svg width="30" height="30" viewBox="0 0 40 40" fill="none" aria-hidden="true"><path d="M12.8889 32.5982C12.666 31.7661 13.1598 30.9108 13.9919 30.6879L30.2971 26.3189C31.1292 26.096 31.9845 26.5898 32.2075 27.4219L32.8739 29.9089C33.1711 31.0183 32.5127 32.1587 31.4033 32.456L18.1113 36.0176C15.8924 36.6121 13.6116 35.2953 13.0171 33.0764L12.8889 32.5982Z" fill="#4F46E5"/><path d="M7.62314 12.946C7.05137 10.8121 8.3177 8.61876 10.4516 8.04699L16.8851 32.0571L13.0214 33.0924L7.62314 12.946Z" fill="#4F46E5"/><path d="M29.3358 24.432L31.2677 23.9144L32.3584 27.985C32.6443 29.052 32.0111 30.1486 30.9442 30.4345L29.3358 24.432Z" fill="#4338CA"/><path d="M26.4446 5.91475C26.1474 4.80529 25.007 4.14688 23.8975 4.44416L10.5286 8.02636C9.41911 8.32364 8.7607 9.46403 9.05798 10.5735L14.9532 32.5748L22.6461 30.5135C23.1986 30.3654 23.5265 29.7975 23.3785 29.245C23.2304 28.6925 23.5583 28.1245 24.1108 27.9765L29.7949 26.4535C30.9043 26.1562 31.5628 25.0158 31.2655 23.9063L26.4446 5.91475Z" fill="#6366F1"/><path d="M14.9532 32.5748C14.6571 31.4697 15.3129 30.3339 16.4179 30.0378L29.8719 26.4328L30.9441 30.4345L17.4902 34.0395C16.3851 34.3356 15.2493 33.6798 14.9532 32.5748Z" fill="#EEF2FF"/></svg>
          <span class="footer-mark-text">
            <span class="footer-mark-name">Hardcover</span>
            <span class="footer-mark-sub">docs</span>
          </span>
        </div>
        <p class="footer-tagline">
          The book-tracking platform for readers. Build with the API, or help curate the world's library.
        </p>
        <div class="footer-apps">
          <a class="footer-app" href={URLS.APP_STORE} target="_blank" rel="noreferrer noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 12.3c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.8-1.8-3.4-1.8-1.4-.1-2.8.9-3.5.9s-1.8-.8-3-.8c-1.5 0-2.9.9-3.7 2.3-1.6 2.7-.4 6.8 1.1 9 .7 1.1 1.6 2.3 2.7 2.2 1.1 0 1.5-.7 2.8-.7s1.7.7 2.8.7c1.2 0 1.9-1.1 2.6-2.2.8-1.2 1.2-2.4 1.2-2.5-.1 0-2.2-.9-2.2-3.3zM15.3 5.3c.6-.7 1-1.7.9-2.7-.9 0-1.9.6-2.5 1.3-.6.6-1 1.6-.9 2.6 1 .1 1.9-.5 2.5-1.2z"/></svg>
            App Store
          </a>
          <a class="footer-app" href={URLS.PLAY_STORE} target="_blank" rel="noreferrer noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3.6 2.3 13 12 3.6 21.7c-.4-.2-.6-.6-.6-1.1V3.4c0-.5.2-.9.6-1.1zM14.7 13.7l2.4 2.4-9.6 5.5zM17.8 10.6l3 1.7c.7.4.7 1.4 0 1.8l-3 1.7-2.7-2.6zM7.5 2.4l9.6 5.5-2.4 2.4z"/></svg>
            Google Play
          </a>
        </div>
      </div>

      <div class="footer-cols">
        {columns.map((col) => (
          <div class="footer-col">
            <div class="footer-col-title">{col.title}</div>
            <div class="footer-col-links">
              {col.links.map((l) => <a href={l.href}>{l.label}</a>)}
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© {year} Hardcover · Built with Astro + Starlight</span>
      <div class="footer-social"><SocialIcons iconSize="15px" /></div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--hc-rule);
    background: var(--hc-paper-2);
    /* Only rendered on full-width (no-sidebar) pages — full-bleed to viewport. */
    width: 100vw;
    margin-inline-start: calc(50% - 50vw);
  }
  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(2.25rem, 4vw, 2.75rem) clamp(1.25rem, 4vw, 3.5rem) 2rem;
  }
  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 32px;
  }

  /* Brand */
  .footer-brand { max-width: 300px; }
  .footer-mark {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .footer-mark-text { line-height: 1; }
  .footer-mark-name {
    display: block;
    font-weight: 600;
    font-size: 15px;
    color: var(--hc-ink);
  }
  .footer-mark-sub {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--hc-ink-3);
    margin-top: 2px;
  }
  .footer-tagline {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--hc-ink-3);
    margin: 14px 0 0;
  }
  .footer-apps {
    display: flex;
    gap: 8px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  .footer-app {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--hc-ink);
    border: 1px solid var(--hc-rule);
    border-radius: 8px;
    padding: 7px 11px;
    background: var(--hc-card);
    text-decoration: none;
    transition: border-color 0.14s ease;
  }
  .footer-app:hover { border-color: var(--hc-indigo-line); }

  /* Columns */
  .footer-cols {
    display: flex;
    gap: clamp(28px, 5vw, 56px);
    flex-wrap: wrap;
  }
  .footer-col-title {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hc-ink-3);
    margin-bottom: 12px;
  }
  .footer-col-links {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .footer-col-links a {
    font-size: 13px;
    color: var(--hc-ink-2);
    text-decoration: none;
  }
  .footer-col-links a:hover { color: var(--hc-indigo); }

  /* Bottom bar */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 36px;
    padding-top: 20px;
    border-top: 1px solid var(--hc-rule);
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer-copy {
    font-size: 12px;
    color: var(--hc-ink-3);
  }
  .footer-social {
    display: flex;
    align-items: center;
    gap: 2px;
  }
  /* Consistent muted glyphs, indigo on hover. Set colour on the svg directly
     (fill + stroke via currentColor) so the shared component's accent doesn't
     leak through on the filled icons. Hide the redundant Hardcover glyph. */
  .footer-social :global(a.sl-flex) {
    color: var(--hc-ink-3);
    padding: 6px;
    margin: 0;
  }
  .footer-social :global(a.sl-flex svg) {
    color: var(--hc-ink-3);
    fill: currentColor;
    width: 16px;
    height: 16px;
  }
  .footer-social :global(a.sl-flex:hover),
  .footer-social :global(a.sl-flex:hover svg) {
    color: var(--hc-indigo);
    opacity: 1;
  }
  .footer-social :global(a.sl-flex:has(svg.hc-icon)) {
    display: none;
  }
</style>
