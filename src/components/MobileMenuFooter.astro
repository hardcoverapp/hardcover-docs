---
/**
 * MobileMenuFooter override — Starlight's version carries socials/theme/locale;
 * this adds the "Open app" CTA so the header's one non-navigational control
 * survives on small screens.
 *
 * Deliberately no section links: this renders directly beneath the sidebar tree,
 * which already lists those pages (and with translated labels). Splash pages get
 * them from the SiteHeader disclosure instead — Starlight only mounts the mobile
 * menu when `hasSidebar`, so they never see this component.
 */
import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import ThemeSelect from '@astrojs/starlight/components/ThemeSelect.astro';

import SocialIcons from './SocialIcons.astro';
import {useTranslation} from '@/lib/utils';
import {URLS} from '@/Consts';

const locale = Astro.currentLocale;
---

<a class="mobile-open-app" href={URLS.APP} target="_blank"
   rel="noreferrer noopener">{useTranslation('ui.nav.openApp', locale)}</a>

<div class="mobile-preferences sl-flex">
    <div class="social-icons">
        <SocialIcons/>
    </div>
    <ThemeSelect/>
    <LanguageSelect/>
</div>

<style>
    @layer starlight.core {
        .social-icons {
            display: flex;
            margin-inline-end: auto;
            gap: 1rem;
            align-items: center;
            padding-block: 1rem;
        }

        .social-icons:empty {
            display: none;
        }

        .mobile-preferences {
            justify-content: space-between;
            flex-wrap: wrap;
            border-top: 1px solid var(--sl-color-gray-6);
            column-gap: 1rem;
            padding: 0.5rem 0;
        }
    }

    .mobile-open-app {
        display: flex;
        justify-content: center;
        background: var(--hc-ink);
        color: var(--hc-paper);
        border: 1px solid var(--hc-ink);
        font-size: 13.5px;
        font-weight: 600;
        padding: 10px 15px;
        border-radius: 9px;
        text-decoration: none;
        margin-block: 0.5rem;
    }
</style>
