---
import { FaFlag } from "react-icons/fa";
---

<span
    style="display:inline-flex;align-items:center;gap:0.4rem;background-color:var(--muted);color:var(--muted-foreground);border-radius:4px;border:1px solid var(--accent);padding:0.1rem 0.24rem;font-size:0.85em;line-height:1.1;vertical-align:baseline;"
>
    <FaFlag aria-hidden="true" size="0.8em" style={{ flexShrink: 0 }} />
    <span>Flag</span>
</span>
