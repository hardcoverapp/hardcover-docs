---
import { Image } from "astro:assets";

interface Props {
  imagePath: string;
  description: string;
}

const { imagePath, description } = Astro.props as Props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "src/content/images/**/*.{png,jpg,jpeg,gif,webp}", 
  { eager: true }
);

if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: src/content/images/**/*.{png,jpg,jpeg,gif,webp}.`,
  );

const imageSrc = images[imagePath].default;
---

<figure class="my-8">
  <Image
    src={imageSrc}
    alt={description}
    class="w-full"
  />
  <figcaption class="mt-2 text-sm leading-6" style="color: var(--muted-foreground); opacity: 0.82;">
    {description}
  </figcaption>
</figure>
