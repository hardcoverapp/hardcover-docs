# Supply-chain hardening: refuse package versions published less than 7 days
# ago, so malicious releases (typically yanked within hours) age out before we
# install them. Requires npm >= 11.10.0.
min-release-age=7

# Note: engine-strict is intentionally NOT set here. It conflicts with
# Dependabot's npm updater ("Due to the engine-strict setting, the update will
# not succeed"), so npm only warns on an engines mismatch (see package.json
# "engines") rather than hard-failing. The .nvmrc Node 24 pin still provides
# npm >= 11.10 in dev and CI, which is what min-release-age above needs.
