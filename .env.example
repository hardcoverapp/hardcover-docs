# Copy this file to .env and fill in your values. .env is gitignored.

# Bearer token for the Hardcover GraphQL API, used by the schema-docs pipeline
# (scripts/schema-tools/update-all.sh). Get it from your Hardcover account's
# API settings. Use the raw token only -- do NOT include the "Bearer " prefix,
# the script adds that itself. Keep the quotes so the value survives `source`.
HARDCOVER_API_TOKEN=""

# GitHub token used by scripts/update-github-stars.js to avoid rate limits.
# Optional; the script works unauthenticated but with lower limits.
GITHUB_TOKEN=""
